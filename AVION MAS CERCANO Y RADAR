unsigned long lastUpdate = 0;
const int updateInterval = 30;
int countdown = 30;
bool modoRadar = false;

// Verde lima fosforescente para la cuadrícula del radar
#define COLOR_RADAR_GRID  0x07C0

struct Avion {
    String vuelo;
    String pais;
    float lat;
    float lon;
    float dist;
    int alt;
    int vel;
    float rumbo;        // -1.0 si el avión no reporta rumbo
    float tasaVertical;
    bool enTierra;
};

std::vector<Avion> listaActual;
uint16_t coloresAvion[3] = { ILI9341_YELLOW, ILI9341_CYAN, ILI9341_MAGENTA };

// ================================================================
// FUNCIONES MATEMÁTICAS
// ================================================================

float calcularDistancia(float lat1, float lon1, float lat2, float lon2) {
    float dLat = (lat2 - lat1) * M_PI / 180.0;
    float dLon = (lon2 - lon1) * M_PI / 180.0;
    float a = sin(dLat/2)*sin(dLat/2) +
              cos(lat1*M_PI/180.0)*cos(lat2*M_PI/180.0)*
              sin(dLon/2)*sin(dLon/2);
    return 6371.0 * (2 * atan2(sqrt(a), sqrt(1-a)));
}

String rumboATexto(float grados) {
    if (grados < 0)                        return "N/D";
    if (grados >= 337.5 || grados < 22.5) return "NORTE";
    if (grados < 67.5)                    return "NORESTE";
    if (grados < 112.5)                   return "ESTE";
    if (grados < 157.5)                   return "SURESTE";
    if (grados < 202.5)                   return "SUR";
    if (grados < 247.5)                   return "SUROESTE";
    if (grados < 292.5)                   return "OESTE";
    if (grados < 337.5)                   return "NOROESTE";
    return "N/D";
}

